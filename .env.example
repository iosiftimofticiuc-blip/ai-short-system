# ─── AI APIs ──────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...

# ─── TIKTOK ───────────────────────────────────────────────
# https://developers.tiktok.com/apps
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=

# ─── YOUTUBE ──────────────────────────────────────────────
# https://console.cloud.google.com (YouTube Data API v3)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ─── INSTAGRAM / FACEBOOK ─────────────────────────────────
# https://developers.facebook.com (Instagram Graph API)
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ID=
FACEBOOK_PAGE_ID=

# ─── PUBLIC VIDEO HOSTING (required for Instagram Reels) ──
# IG Graph API requires a publicly reachable video URL.
# Options: Cloudflare R2 (free tier), S3, or serve output/ via nginx on your VPS.
# Example: https://cdn.yourdomain.com/videos  (must serve the .mp4 by filename)
PUBLIC_VIDEO_URL_BASE=

# ─── CONFIG ───────────────────────────────────────────────
NICHE=Psychology and Science Facts
LANGUAGE=English
VOICE=onyx
TIMEZONE=Europe/Bucharest
