# Enforce LF line endings for all text files (project runs on Linux VPS).
* text=auto eol=lf

# Shell scripts MUST be LF — CRLF breaks bash on Ubuntu.
*.sh   text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf

# Binary files — no conversion.
*.mp4  binary
*.mp3  binary
*.png  binary
*.jpg  binary
